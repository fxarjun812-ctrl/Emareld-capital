<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Emerald Capital - Trading Terminal</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #121212; color: white; margin: 0; padding: 20px; }
        .section { background-color: #1e1e1e; padding: 20px; margin-bottom: 20px; border-radius: 8px; }
        .hidden { display: none; }
        button { background-color: #00c853; color: white; padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer; margin: 5px; }
        button:hover { background-color: #009624; }
        input, select { padding: 10px; margin-top: 10px; border-radius: 5px; border: none; width: 90%; max-width: 300px; }
        .alert-text { color: #ff5252; font-size: 0.9em; font-weight: bold; }
    </style>
</head>
<body>

    <!-- 1. GOOGLE LOGIN SECTION -->
    <div id="login-section" class="section">
        <h2>Welcome to Emerald Capital</h2>
        <p>Login to access your trading terminal.</p>
        <!-- Firebase Auth will attach to this button -->
        <button id="google-login-btn" onclick="simulateLogin()">Login with Google</button>
    </div>

    <!-- MAIN APP (Hidden until logged in) -->
    <div id="main-app" class="hidden">
        
        <!-- 2. DASHBOARD SECTION -->
        <div class="section" id="dashboard">
            <h2>Dashboard</h2>
            <p><strong>Trader:</strong> <span id="user-name">Loading...</span></p>
            <p><strong>Balance:</strong> $0.00 | <strong>Equity:</strong> $0.00 | <strong>Margin:</strong> $0.00</p>
            <p><em>Overall PnL:</em> <span style="color: gray;">0.00</span></p>
        </div>

        <!-- 3. TRADING TERMINAL SECTION -->
        <div class="section" id="terminal">
            <h2>Emerald Terminal</h2>
            <p style="color: gray; font-size: 0.8em;">Note: Platform spread is fixed at 0.05 cents.</p>
            <!-- Here we will later inject TradingView Lightweight Charts -->
            <div style="height: 300px; background-color: #000; border: 1px solid #333; display: flex; align-items: center; justify-content: center;">
                [ Live Chart Data Area ]
            </div>
            <div style="margin-top: 15px;">
                <button style="background-color: #ff5252;">Sell (Bid)</button>
                <button style="background-color: #00c853;">Buy (Ask + 0.05)</button>
            </div>
        </div>

        <!-- 4. FUNDS SECTION -->
        <div class="section" id="funds">
            <h2>Funds Management</h2>
            
            <div style="display: flex; gap: 20px;">
                <!-- DEPOSIT AREA -->
                <div style="flex: 1; border-right: 1px solid #333; padding-right: 20px;">
                    <h3>Deposit</h3>
                    <select id="payment-method" onchange="showPaymentDetails()">
                        <option value="">Select Method...</option>
                        <option value="upi">UPI</option>
                        <option value="bank">Bank Transfer</option>
                        <option value="crypto">Crypto (USDT)</option>
                    </select>

                    <div id="amount-section" class="hidden">
                        <input type="number" id="deposit-amount" placeholder="Enter Amount ($)">
                        
                        <div id="payment-details" style="margin-top: 15px; padding: 10px; background-color: #2c2c2c; border-radius: 5px;">
                            <!-- Payment details injected here via JS -->
                        </div>
                        
                        <button onclick="submitPayment()" style="margin-top: 15px; width: 100%;">I Have Paid</button>
                    </div>
                </div>

                <!-- WITHDRAWAL AREA -->
                <div style="flex: 1; padding-left: 20px;">
                    <h3>Withdraw</h3>
                    <p class="alert-text">⚠️ Withdrawal Policy: You can only withdraw a maximum of 10% of your total balance per month.</p>
                    <input type="number" placeholder="Withdraw Amount ($)">
                    <button style="margin-top: 15px; background-color: #2196f3;">Request Withdrawal</button>
                </div>
            </div>
        </div>

    </div>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        // Simulate Google Login for now
        function simulateLogin() {
            document.getElementById('login-section').classList.add('hidden');
            document.getElementById('main-app').classList.remove('hidden');
            document.getElementById('user-name').innerText = "Trader_001 (Google Verified)";
        }

        // Show payment details based on selection
        function showPaymentDetails() {
            const method = document.getElementById('payment-method').value;
            const amountSection = document.getElementById('amount-section');
            const detailsBox = document.getElementById('payment-details');
            
            if (method === "") {
                amountSection.classList.add('hidden');
                return;
            }
            
            amountSection.classList.remove('hidden');
            
            if (method === 'upi') {
                detailsBox.innerHTML = "<strong>UPI ID:</strong> random123@ybl<br><small>Send exact amount and click 'I Have Paid'.</small>";
            } else if (method === 'bank') {
                detailsBox.innerHTML = "<strong>Bank Name:</strong> Global Demo Bank<br><strong>A/C:</strong> 000123456789<br><strong>IFSC:</strong> DEMO0001234";
            } else if (method === 'crypto') {
                detailsBox.innerHTML = "<strong>USDT (TRC20) Address:</strong><br>T9randomCryptoAddressPlaceholder456";
            }
        }

        // Handle Payment Submission (This will trigger the email later)
        function submitPayment() {
            const amount = document.getElementById('deposit-amount').value;
            if(!amount || amount <= 0) {
                alert("Please enter a valid amount.");
                return;
            }
            // In a real app, this sends a POST request to your Python backend to send the email
            alert("Payment request for $" + amount + " submitted! An email alert has been sent to admin.");
        }
    </script>
</body>
</html>
